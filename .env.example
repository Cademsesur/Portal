# ──────────────────────────────────────────────
# SESUR FLOW — Variables d'environnement (exemple)
# Copier ce fichier vers .env (racine) puis adapter
# ──────────────────────────────────────────────

# Backend
NODE_ENV=development
BACKEND_PORT=4000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://sesur:sesur@localhost:5432/sesur_flow?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change-me-in-production-please-use-strong-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Microsoft Entra ID
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:4000/api/v1/auth/microsoft/callback
ENTRA_ALLOWED_EMAIL_DOMAINS=sesur.com,sesur.bj

# Google OAuth (Client OAuth type Web créé dans Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/auth/google/callback

# Emails promus automatiquement en SUPER_ADMIN au login SSO (CSV)
SUPERADMIN_EMAILS=

# Mail (SMTP)
MAIL_FROM=noreply@sesur.bj
# Par défaut : MailHog (capture les mails sans les envoyer, UI sur :8025)
# Pour un vrai SMTP : remplacer host/port et renseigner SMTP_USER / SMTP_PASSWORD
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
# SMTP_SECURE=true pour TLS implicite (port 465). false pour STARTTLS (port 587) ou plain.
SMTP_SECURE=false

# Object storage (S3 / MinIO en local)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=sesur-flow
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false

# Frontend (Next.js — préfixe NEXT_PUBLIC_ pour exposer)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_NAME=SESUR FLOW
