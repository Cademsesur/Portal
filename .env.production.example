# ============================================================
# .env.production — à placer dans /home/ubuntu/sesur-flow/.env
# sur la VM (PAS dans le repo : ce fichier doit rester ignoré)
#
# Copie ce template, renseigne les <valeurs>, puis renomme en .env
# ============================================================

# === App ===
NODE_ENV=production
BACKEND_PORT=4000
FRONTEND_URL=https://34.214.142.8.nip.io
BACKEND_URL=https://34.214.142.8.nip.io

# === PostgreSQL (container) ===
POSTGRES_USER=sesur
POSTGRES_PASSWORD=<générer un mot de passe fort, ex: openssl rand -base64 24>
POSTGRES_DB=sesur_flow
# DATABASE_URL est construite automatiquement par compose. Ne pas la dupliquer ici.

# === Redis (optionnel — pas utilisé encore) ===
REDIS_HOST=localhost
REDIS_PORT=6379

# === JWT ===
# Générer avec: openssl rand -base64 48
JWT_SECRET=<chaîne aléatoire d'au moins 16 caractères>
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# === Microsoft Entra ID ===
ENTRA_TENANT_ID=972ff553-9b84-4f2f-b25b-d48e3bdac45c
ENTRA_CLIENT_ID=<ton-client-id-Azure>
ENTRA_CLIENT_SECRET=<ton-secret-Azure>
ENTRA_REDIRECT_URI=https://34.214.142.8.nip.io/api/v1/auth/microsoft/callback
ENTRA_ALLOWED_EMAIL_DOMAINS=sesur.com,sesur.bj

# === Super admin (bootstrap) ===
SUPERADMIN_EMAILS=cadangnitode@sesur.bj

# === SMTP Office 365 ===
MAIL_FROM=no-reply@sesur.bj
MAIL_FROM_NAME=WEBSESUR
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=no-reply@sesur.bj
SMTP_PASSWORD=<le-mot-de-passe-O365>
SMTP_SECURE=false

# === Cookies cross-site ===
# Front et back sur le même domaine (via Caddy) → false suffit.
CROSS_SITE_AUTH=false
